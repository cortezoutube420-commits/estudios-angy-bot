# ✝️ BOT BÍBLICO — Variables de Entorno
# Copia este archivo a .env y llena los valores

# ── GROQ (IA gratuita) ──────────────────────
# Regístrate en https://console.groq.com
# Crea una API Key en "API Keys"
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GREEN API (WhatsApp gratuita) ───────────
# Regístrate en https://green-api.com
# Crea una instancia y escanea el QR con tu WhatsApp
GREEN_INSTANCE_ID=1234567890
GREEN_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SERVIDOR ────────────────────────────────
PORT=3000
